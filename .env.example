DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wcp_outbound
ENVIRONMENT=development

# Redis — use rediss:// for TLS (Upstash, Railway)
REDIS_URL=rediss://:your_password@your-endpoint.upstash.io:6380

# Smartlead
SMARTLEAD_API_KEY=your_smartlead_api_key_here
SMARTLEAD_WEBHOOK_SECRET=choose_a_strong_random_string_here
