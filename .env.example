DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wcp_outbound
ENVIRONMENT=development

# Redis — use rediss:// for TLS (Upstash, Railway)
REDIS_URL=rediss://:your_password@your-endpoint.upstash.io:6380

# Smartlead
SMARTLEAD_API_KEY=your_smartlead_api_key_here
SMARTLEAD_WEBHOOK_SECRET=choose_a_strong_random_string_here

# HubSpot — create a Private App in Settings > Integrations > Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.contacts.read,
#                  crm.objects.deals.write, crm.objects.deals.read
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
HUBSPOT_DEAL_PIPELINE_ID=default
HUBSPOT_DEAL_STAGE_ID=1114790192

# API authentication — set a strong random string; empty = auth disabled (dev only)
API_KEY=choose_a_strong_random_string_here

# Dashboard login — set both values in production
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=choose_a_strong_password_here
SESSION_SECRET=choose_a_random_64_char_string_here
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# Apollo.io — contact enrichment (People Match API)
APOLLO_API_KEY=your_apollo_api_key_here

# Hunter.io — email finder fallback when Apollo returns no email
HUNTER_API_KEY=your_hunter_api_key_here
